{
    "family": "docto-frontend",
    "containerDefinitions": [
        {
            "name": "frontend",
            "image": "REPLACE_WITH_IMAGE_URL",
            "cpu": 256,
            "memory": 512,
            "portMappings": [
                {
                    "containerPort": 5173,
                    "hostPort": 5173,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/docto-frontend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::321570168140:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::321570168140:role/ecsTaskExecutionRole"
}
